        {
          "name": "TC-PDS-11: Advanced Search Validation – Internationalization & Mandatory Schema Constraints",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// --- SENIOR QA VALIDATION SCRIPT ---",
                  "",
                  "// 1. Success Validation",
                  "pm.test(\"Status code is 200 - Search Accepted\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 2. Internationalization (i18n) Verification",
                  "pm.test(\"i18n Check: Request URL preserves accented 'í'\", function () {",
                  "    const decodedUrl = decodeURIComponent(pm.request.url.toString());",
                  "    pm.expect(decodedUrl).to.include(\"Díaz\");",
                  "});",
                  "",
                  "// 3. Schema Check",
                  "pm.test(\"FHIR Compliance: Response is valid JSON\", function () {",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// 4. Performance SLA",
                  "pm.test(\"SLA Check: Response time < 2s\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/Patient?family=Díaz&gender=male&birthdate=1985-05-15",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "Patient"
              ],
              "query": [
                {
                  "key": "family",
                  "value": "Díaz"
                },
                {
                  "key": "gender",
                  "value": "male"
                },
                {
                  "key": "birthdate",
                  "value": "1985-05-15"
