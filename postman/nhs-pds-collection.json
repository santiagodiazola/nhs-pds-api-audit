                  "    const jsonData = pm.response.json();",
                  "    // We look into the coding array inside details",
                  "    const errorCode = jsonData.issue[0].details.coding[0].code;",
                  "    pm.expect(errorCode).to.equal(\"INVALID_UPDATE\");",
                  "});"
